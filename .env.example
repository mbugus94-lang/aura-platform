NODE_ENV=development
PORT=3000
APP_NAME=Aura Platform
JWT_SECRET=change-me-to-a-long-random-secret-min-32-characters
# Optional: comma-separated allowed origins
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (SQLite - no additional config needed)
# DB_PATH=./server/aura.db

# OpenAI API Key for AI Chat
OPENAI_API_KEY=sk-your-openai-api-key-here

# Email Service (SendGrid or SMTP)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@auraplatform.com
EMAIL_FROM_NAME=Aura Platform

# Or SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
